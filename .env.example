# Application Configuration
APP_NAME=demo
APP_PORT=8080

# Database Configuration
DB_URL=jdbc:mysql://localhost:3306/demo_spring_angular
DB_USERNAME=root
DB_PASSWORD=password_here
DB_DRIVER=com.mysql.cj.jdbc.Driver

# JPA/Hibernate Configuration
JPA_DDL_AUTO=update
JPA_SHOW_SQL=true

# Logging
LOGGING_LEVEL_WEB=INFO
LOGGING_LEVEL_HIBERNATE=DEBUG

# Jackson Configuration
JACKSON_DEFAULT_PROPERTY_INCLUSION=non_null
JACKSON_INDENT_OUTPUT=true

# Error Handling
SERVER_ERROR_INCLUDE_MESSAGE=always
SERVER_ERROR_INCLUDE_BINDING_ERRORS=always
